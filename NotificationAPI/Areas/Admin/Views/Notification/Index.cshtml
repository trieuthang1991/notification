@model NotificationListViewModel
@{
	ViewData["Title"] = "Quản lý thông báo";
}

@Html.AntiForgeryToken()

<div class="container-fluid mb-4">
<div class="card mb-4">
	<div class="card-header bg-light">
		<div class="d-flex justify-content-between align-items-center">
			<div>
				<i class="bi bi-search me-1"></i>
				<strong>Tìm kiếm thông báo</strong>
			</div>
			<button class="btn btn-sm btn-link" type="button" data-bs-toggle="collapse" data-bs-target="#searchCollapse" aria-expanded="true" aria-controls="searchCollapse">
				<i class="bi bi-chevron-down"></i>
			</button>
		</div>
	</div>
	<div class="collapse show" id="searchCollapse">
		<div class="card-body">
			<form method="get" action="@Url.Action("Index", "Notification", new { area = "Admin" })">
				<!-- Bộ lọc cơ bản -->
				<div class="row g-3 mb-3">
					<div class="col-md-6">
						<label for="Title" class="form-label small fw-bold">Tiêu đề</label>
						<div class="input-group">
							<span class="input-group-text"><i class="bi bi-type"></i></span>
							<input type="text" class="form-control" id="Title" name="Title" value="@Model.Filter.Title" placeholder="Nhập tiêu đề thông báo...">
						</div>
					</div>
					<div class="col-md-3">
						<label for="Domain" class="form-label small fw-bold">Tên miền</label>
						<div class="input-group">
							<span class="input-group-text"><i class="bi bi-globe"></i></span>
							<input type="text" class="form-control" id="Domain" name="Domain" value="@Model.Filter.Domain" placeholder="Nhập tên miền...">
						</div>
					</div>
					<div class="col-md-3">
						<label for="UserId" class="form-label small fw-bold">ID người dùng</label>
						<div class="input-group">
							<span class="input-group-text"><i class="bi bi-person"></i></span>
							<input type="text" class="form-control" id="UserId" name="UserId" value="@Model.Filter.UserId" placeholder="Nhập ID người dùng...">
						</div>
					</div>
				</div>

				<!-- Bộ lọc nâng cao -->
				<div class="row g-3 mb-3">
					<div class="col-md-3">
						<label for="Status" class="form-label small fw-bold">Trạng thái</label>
						<select class="form-select" id="Status" name="Status">
							<option value="">Tất cả</option>
							@foreach(var items in EnumsHelper.EnumToDictionary<StatusNotification>()){
								@:<option value="@items.Key" @((int)Model.Filter.Status == items.Key ? "selected" : "")>@items.Value</option>
							}
						</select>
					</div>
					<div class="col-md-3">
						<label for="ShowType" class="form-label small fw-bold">Loại hiển thị</label>
						<select class="form-select" id="ShowType" name="ShowType" >
							<option value="">Tất cả</option>
							@foreach(var items in EnumsHelper.EnumToDictionary<ShowTypeNotification>()){
								@:<option value="@items.Key" @((int)Model.Filter.ShowType == items.Key ? "selected" : "")>@items.Value</option>
							}

						</select>
					</div>
					<div class="col-md-3">
						<label for="Device" class="form-label small fw-bold">Loại thiết bị</label>
						<select class="form-select" id="Device" name="Device">
							<option value="@((int)DeviceType.Unknown)">Tất cả</option>
							@foreach(var items in EnumsHelper.EnumToDictionary<DeviceType>()){
								@:<option value="@items.Key" @((int)Model.Filter.Device == items.Key ? "selected" : "")>@items.Value</option>
							}

						</select>
					</div>
					<div class="col-md-3">
						<label for="LastUpdated" class="form-label small fw-bold">Cập nhật từ ngày</label>
						<div class="input-group">
							<span class="input-group-text"><i class="bi bi-calendar"></i></span>
							<input type="text" class="form-control datepicker" id="LastUpdated" name="LastUpdated"
								   value="@(Model.Filter.LastUpdated > 0 ? XMUtility.XUtility.UnixTime(Model.Filter.LastUpdated).ToString("yyyy-MM-dd HH:mm") : DateTime.Now.AddDays(-30).ToString("yyyy-MM-dd HH:mm"))">
						</div>
					</div>
				</div>

				<!-- Tùy chọn hiển thị -->
				<div class="row g-3 mb-3">
					<div class="col-md-3">
						<label for="PageSize" class="form-label small fw-bold">Số bản ghi/trang</label>
						<select class="form-select" id="PageSize" name="PageSize">
							@foreach(var pageSize in NotificationAPI.Utils.Common.ListPageSize()){
								@:<option value="@pageSize" @(Model.Filter.PageSize == pageSize ? "selected" : "")>@pageSize</option>
							}
						</select>
					</div>
					<div class="col-md-9">
						<div class="d-flex justify-content-end mt-2">
						<a href="@Url.Action("Index", "Notification", new { area = "Admin" })" class="btn btn-outline-secondary me-2">
							<i class="bi bi-x-circle"></i> Xóa bộ lọc
						</a>
						<button type="submit" class="btn btn-primary">
							<i class="bi bi-search"></i> Tìm kiếm
						</button>
						</div>
					</div>
				</div>

				<!-- Nút tìm kiếm -->

			</form>
		</div>
	</div>
</div>

<div class="card">
	<div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
		<div>
			<i class="bi bi-bell me-1"></i>
			<strong>Danh sách thông báo</strong>
			@if (Model.Total > 0)
			{
				<span class="badge bg-light text-dark ms-2">@Model.Total bản ghi</span>
			}
		</div>
		<div>
			@* <button type="button" class="btn btn-light btn-sm me-2" id="enable-batch-mode">
				<i class="bi bi-check2-square"></i> Chọn nhiều
			</button> *@
			<a href="@Url.Action("BatchCreate", "Notification", new { area = "Admin" })" class="btn btn-light btn-sm me-2">
				<i class="bi bi-file-earmark-plus"></i> Tạo nhiều thông báo
			</a>
			<a href="@Url.Action("Create", "Notification", new { area = "Admin" })" class="btn btn-success btn-sm">
				<i class="bi bi-plus-circle"></i> Thêm mới
			</a>
		</div>
	</div>
	<div class="card-header bg-light d-flex justify-content-between align-items-center" id="batch-actions" style="display: none !important;">
		<div>
			<span class="me-2"><strong><span id="selected-count">0</span> thông báo được chọn</strong></span>
			<div class="form-check form-check-inline">
				<input class="form-check-input" type="checkbox" id="select-all" value="">
				<label class="form-check-label" for="select-all">Chọn tất cả</label>
			</div>
		</div>
		<div>
			<div class="btn-group" role="group">
				<button type="button" class="btn btn-outline-success btn-sm" id="batch-activate">
					<i class="bi bi-toggle2-on"></i> Kích hoạt hàng loạt
				</button>
				<button type="button" class="btn btn-outline-warning btn-sm" id="batch-deactivate">
					<i class="bi bi-toggle2-off"></i> Vô hiệu hóa hàng loạt
				</button>
				<button type="button" class="btn btn-outline-danger btn-sm" id="batch-delete">
					<i class="bi bi-trash"></i> Xóa hàng loạt
				</button>
				<button type="button" class="btn btn-outline-secondary btn-sm" id="cancel-batch">
					<i class="bi bi-x-circle"></i> Hủy
				</button>
			</div>
		</div>
	</div>
	<div class="card-body p-0">
		<div class="table-responsive">
			<table class="table table-striped table-hover table-bordered m-0">
				<thead class="table-light">
					<tr>
						<th style="width: 5%; display: none;" class="text-center batch-column"><input type="checkbox" id="select-all-header"></th>
						<th style="width: 20%">Thông tin cơ bản</th>
						<th style="width: 15%">Phạm vi hiển thị</th>
						<th style="width: 20%">Thời gian</th>
						<th style="width: 10%">Trạng thái</th>
						<th style="width: 15%" class="text-center">Thao tác</th>
					</tr>
				</thead>
				<tbody>
					@if (Model.Notifications != null && Model.Notifications.Any())
					{
						foreach (var item in Model.Notifications)
						{
							<tr>
								<td class="text-center batch-column" style="display: none;">
									<input type="checkbox" class="notification-checkbox" data-id="@item.Id">
								</td>
								<td>
									<div class="d-flex flex-column">
									   <span><strong>ID:</strong>  @item.Id</span>
										<strong>@item.Title</strong>
										<small>
											Kiểu hiển thị:
											@if (item.ShowTypes != null && item.ShowTypes.Any())
											{
												foreach (var type in item.ShowTypes)
												{
													<span class="badge bg-info me-1">@type</span>
												}
											}
										</small>
									</div>
								</td>
								<td>
									<div class="d-flex flex-column">
										<small><strong>Tên miền:</strong></small>
										<small>
											@if (item.Domains != null && item.Domains.Any())
											{
												@string.Join(", ", item.Domains)
											}
										</small>
										<small class="mt-1"><strong>Người dùng:</strong> @item.UserId</small>
									</div>
								</td>
								<td>
									<div class="d-flex flex-column">
										<small><i class="bi bi-calendar-check"></i> <strong>Bắt đầu:</strong></small>
										<small>@XMUtility.XUtility.UnixTime(item.StartDate).ToString("dd/MM/yyyy HH:mm")</small>
										<small class="mt-1"><i class="bi bi-calendar-x"></i> <strong>Kết thúc:</strong></small>
										<small>@XMUtility.XUtility.UnixTime(item.EndDate).ToString("dd/MM/yyyy HH:mm")</small>
									</div>
								</td>
								<td>
									<div class="d-flex flex-column">
										@if (item.Status == StatusNotification.Active)
										{
											<span class="badge bg-success mb-2"><i class="bi bi-check-circle"></i> Hoạt động</span>
										}
										else if (item.Status == StatusNotification.Inactive)
										{
											<span class="badge bg-danger mb-2"><i class="bi bi-x-circle"></i> Không hoạt động</span>
										}
										else
										{
											<span class="badge bg-secondary mb-2">@item.Status</span>
										}
										<small><i class="bi bi-clock-history"></i> Cập nhật:</small>
										<small>@XMUtility.XUtility.UnixTime(item.LastUpdated).ToString("dd/MM/yyyy HH:mm")</small>

									</div>
								</td>
								<td class="text-center align-middle">
									<div class="btn-group" role="group">
										<a href="@Url.Action("Edit", "Notification", new { area = "Admin", id = item.Id })" class="btn btn-outline-primary btn-sm" data-bs-toggle="tooltip" title="Chỉnh sửa">
											<i class="bi bi-pencil"></i>
										</a>
										<button type="button" class="btn @(item.Status == StatusNotification.Active ? "btn-outline-warning" : "btn-outline-success") btn-sm toggle-status"
												data-id="@item.Id"
												data-status="@(item.Status == StatusNotification.Active ? StatusNotification.Inactive : StatusNotification.Active)"
												data-bs-toggle="tooltip"
												title="@(item.Status == StatusNotification.Active ? "Vô hiệu hóa" : "Kích hoạt")">
											<i class="bi @(item.Status == StatusNotification.Active ? "bi-toggle2-off" : "bi-toggle2-on")"></i>
										</button>
										<a href="@Url.Action("BatchCreate", "Notification", new { area = "Admin", sourceId = item.Id })" class="btn btn-outline-info btn-sm" data-bs-toggle="tooltip" title="Nhân bản thông báo">
											<i class="bi bi-file-earmark-plus"></i>
										</a>
										<a href="@Url.Action("Delete", "Notification", new { area = "Admin", id = item.Id })" class="btn btn-outline-danger btn-sm" data-bs-toggle="tooltip" title="Xóa">
											<i class="bi bi-trash"></i>
										</a>
									</div>
									@if (Model.NotificationStatus.ContainsKey(item.Id))
									{
										var status = Model.NotificationStatus[item.Id];
										<div style="text-align:left;margin-top:10px;margin-left:10px">
											<p style="margin-bottom:0"><i class="bi bi-eye"></i> @XMUtility.XUtility.UnixTime(status.LastShown).ToString("dd/MM/yyyy HH:mm")</p>
											<p style="margin-bottom:0"><i class="bi bi-eye"></i> Đã hiển thị: @status.RemainingShows</p>
											@* <p style="margin-bottom:0"><i class="bi bi-hand-thumbs-up"></i> Đã click: @status.LastClick</p> *@
										</div>

									}
								</td>
							</tr>
						}
					}
					else
					{
						<tr>
							<td colspan="6" class="text-center py-4">
								<div class="text-muted">
									<i class="bi bi-inbox fs-2 d-block mb-2"></i>
									Không có dữ liệu thông báo
								</div>
							</td>
						</tr>
					}
				</tbody>
			</table>
		</div>
	</div>

	@if (Model.Total > 0)
	{
		int totalPages = (int)Math.Ceiling((double)Model.Total / Model.Filter.PageSize);
		if (totalPages > 1)
		{
			<div class="card-footer">
				<nav aria-label="Page navigation">
					<ul class="pagination justify-content-center mb-0">
						@if (Model.Filter.PageIndex > 1)
						{
							<li class="page-item">
								<a class="page-link" href="@Url.Action("Index", "Notification", new {
									area = "Admin",
									pageIndex = 1,
									pageSize = Model.Filter.PageSize,
									title = Model.Filter.Title,
									domain = Model.Filter.Domain,
									userId = Model.Filter.UserId,
									lastUpdated = Model.Filter.LastUpdated,
									status = Model.Filter.Status,
									showType = Model.Filter.ShowType,
									device = Model.Filter.Device,

								})">
									<i class="bi bi-chevron-double-left"></i>
								</a>
							</li>
							<li class="page-item">
								<a class="page-link" href="@Url.Action("Index", "Notification", new {
									area = "Admin",
									pageIndex = Model.Filter.PageIndex - 1,
									pageSize = Model.Filter.PageSize,
									title = Model.Filter.Title,
									domain = Model.Filter.Domain,
									userId = Model.Filter.UserId,
									lastUpdated = Model.Filter.LastUpdated,
									status = Model.Filter.Status,
									showType = Model.Filter.ShowType,
									deviceType = Model.Filter.Device,

								})">
									<i class="bi bi-chevron-left"></i>
								</a>
							</li>
						}

						@{
							int startPage = Math.Max(1, Model.Filter.PageIndex - 2);
							int endPage = Math.Min(totalPages, startPage + 4);
							if (endPage - startPage < 4 && startPage > 1)
							{
								startPage = Math.Max(1, endPage - 4);
							}
						}

						@for (int i = startPage; i <= endPage; i++)
						{
							<li class="page-item @(i == Model.Filter.PageIndex ? "active" : "")">
								<a class="page-link" href="@Url.Action("Index", "Notification", new {
									area = "Admin",
									pageIndex = i,
									pageSize = Model.Filter.PageSize,
									title = Model.Filter.Title,
									domain = Model.Filter.Domain,
									userId = Model.Filter.UserId,
									lastUpdated = Model.Filter.LastUpdated,
									status = Model.Filter.Status,
									showType = Model.Filter.ShowType,
									device = Model.Filter.Device,

								})">@i</a>
							</li>
						}

						@if (Model.Filter.PageIndex < totalPages)
						{
							<li class="page-item">
								<a class="page-link" href="@Url.Action("Index", "Notification", new {
									area = "Admin",
									pageIndex = Model.Filter.PageIndex + 1,
									pageSize = Model.Filter.PageSize,
									title = Model.Filter.Title,
									domain = Model.Filter.Domain,
									userId = Model.Filter.UserId,
									lastUpdated = Model.Filter.LastUpdated,
									status = Model.Filter.Status,
									showType = Model.Filter.ShowType,
									device = Model.Filter.Device,

								})">
									<i class="bi bi-chevron-right"></i>
								</a>
							</li>
							<li class="page-item">
								<a class="page-link" href="@Url.Action("Index", "Notification", new {
									area = "Admin",
									pageIndex = totalPages,
									pageSize = Model.Filter.PageSize,
									title = Model.Filter.Title,
									domain = Model.Filter.Domain,
									userId = Model.Filter.UserId,
									lastUpdated = Model.Filter.LastUpdated,
									status = Model.Filter.Status,
									showType = Model.Filter.ShowType,
									device = Model.Filter.Device,

								})">
									<i class="bi bi-chevron-double-right"></i>
								</a>
							</li>
						}
					</ul>
				</nav>
			</div>
		}
	}
</div>

</div>
@section Scripts {
		<script>
			$(document).ready(function() {
				// Khởi tạo tooltips
				var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
				var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
					return new bootstrap.Tooltip(tooltipTriggerEl)
				})

				// Xử lý sự kiện khi nhấn nút toggle trạng thái
				$('.toggle-status').on('click', function() {
					var button = $(this);
					var id = button.data('id');
					var status = button.data('status');
					var statusText = status == 1 ? 'kích hoạt' : 'vô hiệu hóa';

					// Hiển thị hộp thoại xác nhận
					if (confirm(`Bạn có chắc chắn muốn ${statusText} thông báo này không?`)) {
						// Hiển thị loading
						button.html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span>');
						button.prop('disabled', true);

						// Gửi yêu cầu AJAX để cập nhật trạng thái
						$.ajax({
							url: '@Url.Action("UpdateStatus", "Notification", new { area = "Admin" })',
							type: 'POST',
							data: {
								id: id,
								status: status,
								__RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
							},
							success: function(response) {
								if (response.success) {
									// Hiển thị thông báo thành công với toastr nếu có
									if (typeof toastr !== 'undefined') {
										toastr.success(response.message);
										setTimeout(function() {
											location.reload();
										}, 1000);
									} else {
										// Fallback to alert
										alert(response.message);
										location.reload();
									}
								} else {
									// Hiển thị thông báo lỗi
									if (typeof toastr !== 'undefined') {
										toastr.error(response.message);
										button.html(status == 1 ? '<i class="bi bi-toggle2-on"></i>' : '<i class="bi bi-toggle2-off"></i>');
										button.prop('disabled', false);
									} else {
										alert(response.message);
										location.reload();
									}
								}
							},
							error: function() {
								if (typeof toastr !== 'undefined') {
									toastr.error('Đã xảy ra lỗi khi cập nhật trạng thái.');
									button.html(status == 1 ? '<i class="bi bi-toggle2-on"></i>' : '<i class="bi bi-toggle2-off"></i>');
									button.prop('disabled', false);
								} else {
									alert('Đã xảy ra lỗi khi cập nhật trạng thái.');
									location.reload();
								}
							}
						});
					}
				});

				// Xử lý datepicker
				$('.datepicker').flatpickr({
					enableTime: true,
					dateFormat: "Y-m-d H:i",
					time_24hr: true,
					allowInput: true,
					placeholder: "Chọn ngày..."
				});
			});
		</script>
}
