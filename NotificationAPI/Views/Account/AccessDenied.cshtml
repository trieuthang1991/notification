@{
    ViewData["Title"] = "Truy cập bị từ chối";
    Layout = "_Layout";
}

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-md-6">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0"><i class="bi bi-exclamation-triangle-fill me-2"></i>Truy cập bị từ chối</h3>
                </div>
                <div class="card-body text-center">
                    <div class="mb-4">
                        <i class="bi bi-lock-fill text-danger" style="font-size: 5rem;"></i>
                    </div>
                    <h4 class="mb-3">Bạn không có quyền truy cập trang này</h4>
                    <p class="mb-4">Vui lòng liên hệ với quản trị viên nếu bạn cho rằng đây là lỗi.</p>
                    <div class="d-flex justify-content-center">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary me-2">
                            <i class="bi bi-house-door me-1"></i>Trang chủ
                        </a>
                        <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Đăng nhập lại
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
